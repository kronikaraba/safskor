# ------------------------------------------------------------------
# SafSkor - sunucu yapılandırması
# Bu dosyayı ".env" olarak kopyalayıp değerleri doldurun.
# Railway'de değerleri "Variables" panelinden tanımlayın.
# ------------------------------------------------------------------

# API-Football (api-sports.io) anahtarı (ZORUNLU)
# Ücretsiz: https://dashboard.api-football.com/register  (100 istek/gün)
API_FOOTBALL_KEY=

# (Opsiyonel) API taban adresi
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# JWT imza anahtarı - prod'da uzun rastgele bir değer KULLANIN
JWT_SECRET=degistir-bunu-uzun-rastgele-bir-deger-yap
JWT_EXPIRES_IN=7d

# Sunucu portu (Railway prod'da PORT'u otomatik enjekte eder, burayı boş bırakabilirsin)
PORT=4000

# CORS - Vercel frontend domain'i. Birden fazlaysa virgülle ayır.
# Örn: CLIENT_ORIGIN=https://safskor.vercel.app,https://safskor-git-main.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Postgres connection string (Neon dashboard'dan al)
# Örn: postgresql://user:pass@ep-something-pooler.neon.tech/safskor?sslmode=require
DATABASE_URL=

# Bu e-postalarla kayıt olan kullanıcılar otomatik admin olur (virgülle ayır)
ADMIN_EMAILS=
